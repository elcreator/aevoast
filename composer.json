{
    "name": "elcreator/aevoast",
    "description": "AST symbol maps and embeddings generator for Evolution CMS — parse core, extras, and custom code into merged, searchable indexes",
    "type": "evolution-cms-package",
    "license": "MIT",
    "homepage": "https://github.com/elcreator/aEvoAST",
    "support": {
        "issues": "https://github.com/elcreator/aEvoAST/issues",
        "source": "https://github.com/elcreator/aEvoAST"
    },
    "authors": [
        {
            "name": "Artur Kyryliuk",
            "homepage": "https://artur.work"
        }
    ],
    "require": {
        "php": ">=8.2",
        "nikic/php-parser": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Elcreator\\aEvoAST\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elcreator\\aEvoAST\\aEvoASTServiceProvider"
            ]
        }
    }
}
